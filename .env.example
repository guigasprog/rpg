# Banco de dados — PostgreSQL (Neon) em dev e produção.
# Use a connection string POOLED do Neon (termina com -pooler...), com sslmode=require.
# Ex.: postgresql://user:senha@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://usuario:senha@host-pooler.regiao.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5 — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_TRUST_HOST=true

# Em produção (Vercel), defina também:
# AUTH_URL="https://seu-projeto.vercel.app"
