// Esquema Prisma — Arquivo Sombrio
// PostgreSQL (Neon) em dev e produção.
// DATABASE_URL: connection string do Neon (use a POOLED, com ?sslmode=require).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // Client clássico em node_modules/@prisma/client (Vercel/Next empacotam o
  // engine automaticamente). Gera engine nativo (dev) + Linux (Vercel).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Papéis: "MASTER" | "PLAYER"
// (SQLite não suporta enums do Prisma; validado em app via src/lib/roles.ts)

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  role         String      @default("PLAYER")
  characters   Character[]
  createdAt    DateTime    @default(now())
}

// Chat/auditoria da mesa: mensagens e rolagens (todos veem; GM audita).
model Message {
  id        String   @id @default(cuid())
  autorNome String
  autorRole String   @default("PLAYER") // MASTER | PLAYER
  autorId   String? // id do autor (para sussurros)
  tipo      String   @default("CHAT") // CHAT | ROLL
  texto     String
  total     Int? // resultado numérico da rolagem, se houver
  // Visibilidade: destinoUserId != null → sussurro (só autor, destino e Mestre).
  destinoUserId String? // sussurro a um jogador específico
  secreta       Boolean @default(false) // rolagem oculta (só o Mestre vê)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// (obsoleto) Narração ao vivo — removida da UI; tabela mantida por ora.
model Broadcast {
  id        String   @id @default(cuid())
  texto     String
  ativo     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ativo])
}

// Mural de Provas / Pistas — quadro de investigação (corkboard) colaborativo.
model Evidence {
  id        String  @id @default(cuid())
  titulo    String
  descricao String  @default("")
  imagemUrl String?
  revelado  Boolean @default(false) // visível aos jogadores no quadro

  // Posição no quadro (coordenadas do canvas, colaborativas).
  x Int @default(0)
  y Int @default(0)

  notas     EvidenceNote[]
  linksDe   EvidenceLink[] @relation("linkFrom")
  linksPara EvidenceLink[] @relation("linkTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([revelado])
}

// Anotação em uma prova (compartilhada entre a mesa; acrescenta ou desmente).
model EvidenceNote {
  id         String   @id @default(cuid())
  evidenceId String
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  autorId    String?
  autorNome  String
  texto      String
  contra     Boolean  @default(false) // true = desmente/contradiz
  createdAt  DateTime @default(now())

  @@index([evidenceId])
}

// Mapa de combate (tabletop). Singleton: id fixo "main".
model GameMap {
  id            String  @id @default("main")
  backgroundUrl String? // imagem de fundo definida pelo Mestre (opcional)
  bgX           Int     @default(0)
  bgY           Int     @default(0)
  bgW           Int     @default(960) // largura da imagem (esticável)
  bgH           Int     @default(640) // altura da imagem (esticável)
  cell          Int     @default(64) // tamanho da célula quadrada (px)
  showGrid      Boolean @default(true)
  updatedAt     DateTime @updatedAt
}

// Peça no mapa (token). Quadrada, do tamanho da célula. Imagem opcional.
model MapToken {
  id          String   @id @default(cuid())
  nome        String   @default("")
  imageUrl    String?
  characterId String? // se veio de um personagem (retrato)
  ownerId     String? // quem controla o token (jogador dono); null = só Mestre
  x           Int      @default(0)
  y           Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

// Ligação entre duas provas ("barbante") para amarrar um fato.
model EvidenceLink {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      Evidence @relation("linkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        Evidence @relation("linkTo", fields: [toId], references: [id], onDelete: Cascade)
  label     String   @default("") // o fato/afirmação que a ligação prova
  autorId   String?
  createdAt DateTime @default(now())

  @@index([fromId])
  @@index([toId])
}

// Ordem de iniciativa do combate (gerida pelo Mestre).
model InitiativeEntry {
  id        String   @id @default(cuid())
  nome      String
  valor     Int      @default(0)
  atual     Boolean  @default(false) // turno atual
  createdAt DateTime @default(now())
}

// Livro do Mestre (entradas criadas pelo GM). Categoria: MONSTRO | LOCAL | RITUAL_PNJ
model LoreEntry {
  id        String   @id @default(cuid())
  categoria String
  titulo    String
  conteudo  String
  perigo    Int      @default(0) // 0-3 (usado sobretudo em monstros)
  imagemUrl String? // link da ilustração/rascunho (colado pelo GM)
  revelado  Boolean  @default(false) // liberado como card de combate p/ jogadores
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria])
}

model Character {
  id          String  @id @default(cuid())
  name        String
  playerName  String
  // Nullable: apagar a conta do dono DESVINCULA o personagem (não apaga).
  ownerId     String?
  owner       User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  arquivado   Boolean @default(false) // dossiê inativo (invisível ao jogador)
  mostrarNaMesa Boolean @default(false) // exibe o retrato na tela de todos
  retratoTravado Boolean @default(false) // trava a foto (jogador não troca)
  portraitUrl String?
  occupation  String?
  appearance  String?

  attrInvestigar Int @default(0)
  attrCombate    Int @default(0)
  attrLabia      Int @default(0)
  attrMente      Int @default(0)

  // Classe: "ESPECIALISTA" | "COMBATENTE" | "OCULTISTA"
  classe            String  @default("ESPECIALISTA")
  subclasse         String? // chave da subclasse (liberada pelo GM)
  nivel             Int     @default(0) // 0-25 (0 = Comum)
  especialistaFocos String? // JSON: até 2 chaves de atributo

  // PV/SAN: máximos derivados (recalculados no servidor). Atuais aceitam
  // sobrevida (> máx) e valores negativos (< 0).
  pvAtual  Int @default(10)
  pvMax    Int @default(10)
  sanAtual Int @default(10)
  sanMax   Int @default(10)

  // Proposta do Além: "NENHUMA" | "PENDENTE" | "ACEITA" | "RECUSADA"
  propostaStatus String  @default("NENHUMA")
  propostaTexto  String?

  // JSON armazenado como texto no SQLite.
  inventory   String? // JSON: string[] de itens
  playerNotes String? // anotações do próprio jogador
  masterNotes String? // NUNCA enviado ao jogador

  occultismUnlocked   Boolean   @default(false)
  occultismLevel      Int       @default(0) // 0-3, revelação gradual
  occultismContent    String? // JSON: conteúdo revelado (só GM ou desbloqueado)
  occultismUnlockedAt DateTime?

  // Condições/estados (Ferido, Sangrando, Em Pânico...). JSON: string[] de chaves.
  condicoes String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}
